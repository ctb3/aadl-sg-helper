# ---------------------------------------------------------------------------
# AADL Summer Game handwriting-extraction bake-off — configuration
# Copy to `.env` and fill in. All values have defaults except cloud credentials.
# ---------------------------------------------------------------------------

# --- AWS (Bedrock + Textract) ---
# Standard AWS credential chain is used (env vars / shared config / SSO).
# Provide creds however you normally do; at minimum set the region.
AWS_REGION=us-east-1
# If your creds live under a named profile in ~/.aws (not [default]), set it:
# AWS_PROFILE=my-profile
# If you use static keys instead of a shared profile, uncomment:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Google Cloud Vision ---
# Path to a service-account JSON key with the Vision API enabled.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/gcp-service-account.json

# --- Bedrock model IDs (must have model access enabled in your region) ---
# These use cross-region inference-profile IDs (the "us." prefix). Adjust the
# region prefix (us./eu./apac.) or drop it to match your Bedrock access.
CLAUDE_READER_MODEL=us.anthropic.claude-sonnet-5
NOVA_READER_MODEL=us.amazon.nova-pro-v1:0
# Vision model used as the model_crop localizer (Nova Lite is too weak — it
# cannot find the handwriting; Nova Pro or Haiku-class works):
LOCALIZER_MODEL=us.amazon.nova-pro-v1:0
# Disable Claude thinking on Bedrock Converse for fast literal JSON (disabled|omit)
CLAUDE_THINKING=disabled

# --- Data locations ---
IMAGES_DIR=data/images
LABELS_PATH=data/labels.csv

# --- Preprocessing / heuristic knobs ---
MAX_EDGE=1500            # downscale longest edge (px) for the `none` arm
CROP_PADDING_PCT=0.15    # padding added around the localizer bbox
# GCV `none`-arm spatial isolation band (fractions of image, origin top-left)
GCV_BAND_TOP=0.55
GCV_BAND_BOTTOM=0.85
GCV_BAND_LEFT=0.15
GCV_BAND_RIGHT=0.85

# --- Rough cost constants (USD) — for the report only, all configurable ---
CLAUDE_IN_PER_MTOK=3.0
CLAUDE_OUT_PER_MTOK=15.0
NOVA_IN_PER_MTOK=0.8
NOVA_OUT_PER_MTOK=3.2
LOCALIZER_IN_PER_MTOK=0.8
LOCALIZER_OUT_PER_MTOK=3.2
TEXTRACT_PER_PAGE=0.0015
GCV_PER_IMAGE=0.0015

# --- Labeler ---
LABEL_PORT=5178

# --- Field-test app (src/app; local `npm run app` + Lambda deploy) ---
# Shared access PIN; requests without it get 401. Empty = no PIN (local dev).
APP_PIN=
# Private S3 bucket for session logs (photo/crop/results/verdicts).
# infra/deploy.sh defaults it to aadl-sg-sessions-<account-id> and creates it.
SESSIONS_BUCKET=
# PORT=8080               # app server port (Lambda Web Adapter convention)
# GCP_SA_KEY_JSON=        # inline service-account JSON; deploy sets this on
#                         # Lambda from GOOGLE_APPLICATION_CREDENTIALS's file
