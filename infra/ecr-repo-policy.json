{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "LambdaECRImageRetrieval",
      "Effect": "Allow",
      "Principal": { "Service": "lambda.amazonaws.com" },
      "Action": ["ecr:BatchGetImage", "ecr:GetDownloadUrlForLayer"],
      "Condition": {
        "StringLike": { "aws:sourceArn": "arn:aws:lambda:us-east-2:619467956318:function:aadl-sg-app" }
      }
    }
  ]
}
