{
  "name": "aadl-sg-helper",
  "version": "1.3.0",
  "private": true,
  "type": "module",
  "description": "AADL Summer Game sign code reader",
  "scripts": {
    "app": "tsx src/app/server.ts",
    "label": "tsx src/harness/label.ts",
    "preflight": "tsx src/harness/preflight.ts",
    "smoke": "tsx src/harness/run.ts --limit 1",
    "bake": "tsx src/harness/run.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-appconfigdata": "^3.1079.0",
    "@aws-sdk/client-bedrock-runtime": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-ssm": "^3.1080.0",
    "@aws-sdk/client-textract": "^3.700.0",
    "@google-cloud/vision": "^5.3.7",
    "dotenv": "^16.4.5",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@aws-sdk/client-bedrock": "^3.1078.0",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
